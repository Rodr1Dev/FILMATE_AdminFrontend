{
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module",
    "ecmaFeatures": { "jsx": true }
  },
  "rules": {
    "no-unused-vars": "off",
    "no-undef": "off",
    "no-empty": ["warn", { "allowEmptyCatch": true }]
  }
}
